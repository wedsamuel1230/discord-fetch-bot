# Discord webhook URL — https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# OpenRouter API key — https://openrouter.ai/ (free tier works for 7 req/day)
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# X (Twitter) account credentials used by twscrape for scraping
X_USERNAME=your_x_username
X_PASSWORD=your_x_password
X_EMAIL=your_x_email@example.com
X_EMAIL_PW=your_email_password

# Optional: comma-separated Nitter mirrors used when twscrape is blocked
# Example: https://nitter.net,https://nitter.privacydev.net
NITTER_BASE_URLS=

# Optional: set true to run once immediately at startup.
# Default behavior is false (do not post anything while booting).
RUN_ON_STARTUP=false
