# Discord webhook URL — https://discord.com/developers/docs/resources/webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Separate startup/init webhook URL for bot boot + self-update notices
# Optional: leave empty to fallback to DISCORD_WEBHOOK_URL
DISCORD_INIT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_INIT_WEBHOOK_ID/YOUR_INIT_WEBHOOK_TOKEN

# OpenRouter API key — https://openrouter.ai/ (free tier works for 7 req/day)
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# Digest mode:
# - follow-builders-hybrid: AI from follow-builders feeds + maker RSS topics locally
# - follow-builders-only: AI from follow-builders feeds only
DIGEST_MODE=follow-builders-hybrid

# follow-builders upstream feed source mode:
# - central: track the latest main-branch curated feed files
# - pinned: lock to a specific commit/tag via FOLLOW_BUILDERS_PINNED_REF
FOLLOW_BUILDERS_SOURCE_MODE=central

# Source rollout wave:
# - wave1: high-signal curated expansion
# - wave2: full expansion set from reference lists
SOURCE_ROLLOUT_MODE=wave1

# Optional mirror base URLs (comma-separated) for follow-builders feeds.
# The bot tries these in order for better resilience/performance.
FOLLOW_BUILDERS_BASE_URLS=https://raw.githubusercontent.com/zarazhangrui/follow-builders/main,https://cdn.jsdelivr.net/gh/zarazhangrui/follow-builders@main

# Required when FOLLOW_BUILDERS_SOURCE_MODE=pinned (example: c68a0c52ab2519a66ab333de571db5670c05e8ae)
FOLLOW_BUILDERS_PINNED_REF=

# Optional explicit feed URL overrides; leave empty to use computed defaults.
FOLLOW_BUILDERS_FEED_X_URL=
FOLLOW_BUILDERS_FEED_PODCASTS_URL=
FOLLOW_BUILDERS_FEED_BLOGS_URL=

# Follow-builders local cache fallback (used when upstream is temporarily unavailable).
FOLLOW_BUILDERS_CACHE_ENABLED=true
FOLLOW_BUILDERS_CACHE_TTL_HOURS=48
FOLLOW_BUILDERS_CACHE_PATH=data/follow_builders_cache.json

# Enable maker RSS topics in hybrid mode.
MAKER_RSS_ENABLED=true

# Comma-separated maker topic names used in hybrid mode.
MAKER_RSS_TOPIC_SET=ESP32,RP2040,Arduino,3D列印

# Enable per-category X (Xer) ingestion via public RSS mirrors.
TOPIC_X_ENABLED=true

# Topic-X recency window in hours (used when filtering handle timelines).
TOPIC_X_LOOKBACK_HOURS=24

# Comma-separated Nitter-compatible RSS base URLs.
TOPIC_X_RSS_BASE_URLS=https://nitter.poast.org,https://nitter.privacydev.net,https://nitter.rawbit.ninja,https://nitter.1d4.us

# Enable topic-level YouTube channel ingestion.
TOPIC_YOUTUBE_ENABLED=true

# YouTube recency window in hours.
YOUTUBE_LOOKBACK_HOURS=48

# Max video items kept per channel each run.
YOUTUBE_MAX_ITEMS_PER_CHANNEL=2

# Optional: disable daily git self-update if this container should stay pinned.
SELF_UPDATE_ENABLED=true

# Optional: repo path / remote / branch for self-update checks.
SELF_UPDATE_REPO_PATH=.
SELF_UPDATE_REMOTE=origin
SELF_UPDATE_BRANCH=main

# Optional: set true to run once immediately at startup.
# Default behavior is false (do not post anything while booting).
RUN_ON_STARTUP=false
